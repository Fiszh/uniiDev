{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["bun"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "$store/*": ["./store/*"],
      "$lib/*": ["./lib/*"],
      "$background/*": ["./background/*"]
    }
  }
}
